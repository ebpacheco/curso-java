		Scanner entrada = new Scanner(System.in);
		valor = entrada.nextInt();
		entrada.close();

		(valor < 0 || valor > 1000000)
		for (int nota : notas) {
			System.out.printf(valor / nota + " nota(s) de R$ %.2f%n", (double) nota);
